# Enforce LF for text files and treat common binary files as binary
*.py text eol=lf
*.pyi text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sh text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.pdf binary
