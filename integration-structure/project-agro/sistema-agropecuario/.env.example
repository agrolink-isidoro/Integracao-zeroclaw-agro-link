# ============================================================
# sistema-agropecuario — template de variáveis de ambiente
# Copie este arquivo para `.env` e preencha com seus valores.
# NUNCA commite o arquivo `.env` (ele está no .gitignore).
# ============================================================

# ── Banco de dados ───────────────────────────────────────────
POSTGRES_USER=agro_user
POSTGRES_PASSWORD=your-strong-db-password
POSTGRES_DB=agro_db
DATABASE_URL=postgresql://agro_user:your-strong-db-password@db:5432/agro_db

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Django ───────────────────────────────────────────────────
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-django-secret-key

# ── Isidoro / LLM (Google Gemini) ───────────────────────────
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
ISIDORO_API_KEY=your-google-gemini-api-key
ISIDORO_LLM_MODEL=gemini-2.5-flash
ISIDORO_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
ISIDORO_LLM_TEMPERATURE=0.3
ISIDORO_AGENT_PASSWORD=your-isidoro-agent-password

# ── Agrolink backend URL (interno Docker) ────────────────────
AGROLINK_API_URL=http://backend:8000/api

# ── Dev bootstrap ────────────────────────────────────────────
DEV_SUPERUSER_PASSWORD=your-admin-password
CREATE_DEV_USER=true
DEBUG=True

# ── Certificado fiscal (NF-e) ────────────────────────────────
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CERT_ENCRYPTION_KEY=your-fernet-key-here

# ── SEFAZ (Homologação = 2 / Produção = 1) ───────────────────
SEFAZ_AMBIENTE=2
SEFAZ_SIMULATE_ONLY=True
SEFAZ_SSL_VERIFY=False
SEFAZ_DISTRIB_ENDPOINT=https://hom.nfe.fazenda.gov.br/NFeDistribuicaoDFe/NFeDistribuicaoDFe.asmx

# ── Google APIs ──────────────────────────────────────────────
# Obtenha sua chave de Maps em: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
