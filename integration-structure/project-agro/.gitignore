# Ignore Windows alternate data streams (Zone.Identifier) created on some files
# These are often added by Windows and are not relevant on Linux/macOS
*:Zone.Identifier
*.Zone.Identifier
**/*:Zone.Identifier
**/*.Zone.Identifier

